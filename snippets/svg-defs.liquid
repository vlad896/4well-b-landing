{%- comment -%}
  Invisible SVG <defs> at the top of <body>.
  Holds the reusable <symbol id="bottle"> referenced by hero, ingredients,
  sticky CTAs, and the final CTA via <svg><use href="#bottle"></use></svg>.
  Source mapping: index.html lines 117-147.
  Font-family swapped to system stack (Inter removed per perf budget).
{%- endcomment -%}
<svg width="0" height="0" style="position:absolute" aria-hidden="true" focusable="false">
  <defs>
    <linearGradient id="bottleBody" x1="0" x2="1" y1="0" y2="1">
      <stop offset="0%" stop-color="#5C3A92"/>
      <stop offset="100%" stop-color="#3A2161"/>
    </linearGradient>
    <linearGradient id="bottleCap" x1="0" x2="0" y1="0" y2="1">
      <stop offset="0%" stop-color="#FFD24A"/>
      <stop offset="100%" stop-color="#E69500"/>
    </linearGradient>
    <symbol id="bottle" viewBox="0 0 220 320">
      <rect x="64" y="6" width="92" height="34" rx="8" fill="url(#bottleCap)"/>
      <rect x="64" y="32" width="92" height="6" fill="#A86A00" opacity=".4"/>
      <rect x="78" y="38" width="64" height="14" fill="#241541"/>
      <rect x="32" y="52" width="156" height="252" rx="22" fill="url(#bottleBody)"/>
      <rect x="44" y="68" width="14" height="220" rx="7" fill="#fff" opacity=".10"/>
      <rect x="48" y="110" width="124" height="156" rx="6" fill="#fff"/>
      <rect x="48" y="110" width="124" height="22" fill="#E63946"/>
      <text x="110" y="126" text-anchor="middle" font-family="system-ui,-apple-system,sans-serif" font-size="11" font-weight="800" fill="#fff" letter-spacing="1">4WELL</text>
      <text x="110" y="160" text-anchor="middle" font-family="system-ui,-apple-system,sans-serif" font-size="28" font-weight="800" fill="#4A2C7A">DIM</text>
      <text x="110" y="180" text-anchor="middle" font-family="system-ui,-apple-system,sans-serif" font-size="11" font-weight="600" fill="#7C7A88">370 MG</text>
      <rect x="68" y="190" width="84" height="1" fill="#ECEAF2"/>
      <text x="110" y="208" text-anchor="middle" font-family="system-ui,-apple-system,sans-serif" font-size="9" font-weight="600" fill="#4A4856">+ BIOPERINE</text>
      <text x="110" y="222" text-anchor="middle" font-family="system-ui,-apple-system,sans-serif" font-size="9" font-weight="600" fill="#4A4856">+ ZINC 15 MG</text>
      <text x="110" y="236" text-anchor="middle" font-family="system-ui,-apple-system,sans-serif" font-size="9" font-weight="600" fill="#4A4856">+ NIACINAMIDE</text>
      <rect x="78" y="246" width="64" height="14" rx="3" fill="#FFB800"/>
      <text x="110" y="256" text-anchor="middle" font-family="system-ui,-apple-system,sans-serif" font-size="9" font-weight="800" fill="#1d1404">30 CAPSULES</text>
    </symbol>
  </defs>
</svg>
