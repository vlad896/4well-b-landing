{%- comment -%}
  trust-badges — reusable row of 5 friction-killer badges (guarantee, shipping, lab, GMP, Made in USA).
  Renders near every primary CTA (hero, final-cta).
  Labels pulled from locale 'shared.trust_badges.*' so a single edit propagates everywhere.

  Usage:
    {%- render 'trust-badges', variant: 'hero' -%}    (compact, light bg — under hero CTA)
    {%- render 'trust-badges', variant: 'final' -%}   (slightly larger, dark labels — under plan cards)

  variant (string, optional, default 'hero'): 'hero' | 'final'
{%- endcomment -%}
{%- assign v = variant | default: 'hero' -%}
<ul class="trust-badges trust-badges--{{ v }}" role="list" aria-label="{{ 'shared.trust_badges.aria' | t }}">
  <li class="trust-badge">
    <span class="trust-badge__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2 4 5v6c0 5 3.5 9 8 11 4.5-2 8-6 8-11V5l-8-3z"/><path d="m9 12 2 2 4-4"/></svg>
    </span>
    <span class="trust-badge__label">{{ 'shared.trust_badges.guarantee' | t }}</span>
  </li>
  <li class="trust-badge">
    <span class="trust-badge__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 7h11v9H3zM14 10h4l3 3v3h-7z"/><circle cx="7" cy="18" r="2"/><circle cx="17" cy="18" r="2"/></svg>
    </span>
    <span class="trust-badge__label">{{ 'shared.trust_badges.shipping' | t }}</span>
  </li>
  <li class="trust-badge">
    <span class="trust-badge__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M9 2h6M10 2v6L5 19a2 2 0 0 0 1.8 3h10.4A2 2 0 0 0 19 19L14 8V2"/><path d="M7.5 15h9"/></svg>
    </span>
    <span class="trust-badge__label">{{ 'shared.trust_badges.lab' | t }}</span>
  </li>
  <li class="trust-badge">
    <span class="trust-badge__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="9" r="6"/><path d="m9 13.5-2 7 5-2.5 5 2.5-2-7"/><path d="m9.5 9 2 2 3-3.5"/></svg>
    </span>
    <span class="trust-badge__label">{{ 'shared.trust_badges.gmp' | t }}</span>
  </li>
  <li class="trust-badge">
    <span class="trust-badge__icon" aria-hidden="true">
      <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="14" rx="1"/><path d="M3 9h18M3 14h18M3 4v14"/><circle cx="7.5" cy="6.5" r="1.5" fill="currentColor"/></svg>
    </span>
    <span class="trust-badge__label">{{ 'shared.trust_badges.usa' | t }}</span>
  </li>
</ul>
