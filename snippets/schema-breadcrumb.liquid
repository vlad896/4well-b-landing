{%- comment -%}
  schema-breadcrumb — BreadcrumbList JSON-LD.
  2-item list (Home → current page); helps Google understand site structure
  even on single-page landings. Data-independent (uses page-level Liquid vars only).
  Rendered from theme.liquid <head>.
{%- endcomment -%}
{%- assign canonical_link = canonical_url -%}
{%- if settings.canonical_url_override != blank -%}
  {%- assign canonical_link = settings.canonical_url_override -%}
{%- endif -%}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": {{ shop.name | json }},
      "item": {{ shop.url | json }}
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": {{ page_title | json }},
      "item": {{ canonical_link | json }}
    }
  ]
}
</script>
