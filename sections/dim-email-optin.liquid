{%- comment -%}
  section: dim-email-optin (inline lead magnet)
  source mapping: index.html block 12.5 (lines 991-1013)
  Turn 18 — per-turn STOP. First <dim-email-optin> Web Component.
  Klaviyo hosted endpoint. compliance.email_consent (shared) for consent text.
  list_id gating:
    - storefront + klaviyo_list_id blank → entire section hidden (no broken form to users)
    - theme editor (design_mode) + blank → form shown with warning so merchant can configure
{%- endcomment -%}

{%- assign klaviyo_id = settings.klaviyo_list_id -%}
{%- assign in_editor = request.design_mode -%}

{%- if klaviyo_id != blank or in_editor -%}
  <section class="email-gate" id="guide" {{ section.shopify_attributes }}>
    <div class="container">
      <div class="email-gate__card">
        {%- if in_editor and klaviyo_id == blank -%}
          <p class="email-gate__warning" role="status">⚠ {{ 'sections.dim_email_optin.editor_warning' | t }}</p>
        {%- endif -%}

        <div class="email-gate__copy">
          {%- if section.settings.eyebrow != blank -%}
            <div class="eyebrow">{{ section.settings.eyebrow }}</div>
          {%- endif -%}
          <h2 class="h2">{{ section.settings.h2 }}</h2>
          {%- if section.settings.lede != blank -%}
            <div class="lede">{{ section.settings.lede }}</div>
          {%- endif -%}
        </div>

        <dim-email-optin
          endpoint="https://manage.kmail-lists.com/ajax/subscriptions/subscribe"
          list-id="{{ klaviyo_id | escape }}"
          source="inline_lead_magnet"
          success-text="{{ section.settings.success_text | escape }}"
          error-text="{{ section.settings.error_text | escape }}"
          loading-text="{{ section.settings.loading_text | escape }}">
          <form class="email-gate__form"
                action="https://manage.kmail-lists.com/ajax/subscriptions/subscribe"
                method="POST"
                novalidate>
            <input type="hidden" name="g" value="{{ klaviyo_id | escape }}">
            <input type="hidden" name="$consent" value="web">
            <input type="hidden" name="$source" value="inline_lead_magnet">
            <input type="text" name="phone" class="email-gate__honeypot" tabindex="-1" autocomplete="off" aria-hidden="true">

            <div class="email-gate__form-row">
              <label for="email-optin-inline-{{ section.id }}" class="visually-hidden">{{ 'sections.dim_email_optin.email_label' | t }}</label>
              <input id="email-optin-inline-{{ section.id }}"
                     type="email"
                     name="email"
                     required
                     autocomplete="email"
                     placeholder="{{ section.settings.field_placeholder | escape }}"
                     class="email-gate__input">
              <button type="submit"
                      class="btn btn--amazon email-gate__submit"
                      data-cta-id="email-optin-submit"
                      data-cta-section="email-optin"
                      data-cta-position="inline">
                {{ section.settings.submit_label }}
              </button>
            </div>

            {%- if section.settings.consent_text != blank -%}
              <p class="email-gate__consent">
                {{ section.settings.consent_text }}
                {%- if section.settings.privacy_url != blank %} <a href="{{ section.settings.privacy_url }}">{{ 'sections.dim_email_optin.privacy_link' | t }}</a>.{%- endif -%}
              </p>
            {%- endif -%}
          </form>

          <div data-success hidden role="status" aria-live="polite" class="email-gate__success"></div>
          <div data-error hidden role="alert" class="email-gate__error"></div>
        </dim-email-optin>
      </div>
    </div>
  </section>

  <script src="{{ 'dim-email-optin.js' | asset_url }}" type="module" defer></script>
{%- endif -%}

{% schema %}
{
  "name": "t:sections.dim_email_optin.section_name",
  "tag": "section",
  "class": "dim-section dim-email-optin-section",
  "settings": [
    { "type": "header", "content": "t:sections.dim_email_optin.header_intro" },
    { "type": "paragraph", "content": "t:sections.dim_email_optin.paragraph_klaviyo_info" },
    { "type": "text",     "id": "eyebrow", "label": "t:sections.dim_email_optin.label_eyebrow", "default": "t:sections.dim_email_optin.eyebrow_default" },
    { "type": "textarea", "id": "h2",      "label": "t:sections.dim_email_optin.label_h2",      "default": "t:sections.dim_email_optin.h2_default" },
    { "type": "richtext", "id": "lede",    "label": "t:sections.dim_email_optin.label_lede",    "default": "t:sections.dim_email_optin.lede_default" },

    { "type": "header", "content": "t:sections.dim_email_optin.header_form" },
    { "type": "text",     "id": "field_placeholder", "label": "t:sections.dim_email_optin.label_field_placeholder", "default": "t:sections.dim_email_optin.field_placeholder_default" },
    { "type": "text",     "id": "submit_label",      "label": "t:sections.dim_email_optin.label_submit_label",      "default": "t:sections.dim_email_optin.submit_label_default" },
    { "type": "text",     "id": "loading_text",      "label": "t:sections.dim_email_optin.label_loading_text",      "default": "t:sections.dim_email_optin.loading_text_default" },
    { "type": "textarea", "id": "success_text",      "label": "t:sections.dim_email_optin.label_success_text",      "default": "t:sections.dim_email_optin.success_text_default" },
    { "type": "textarea", "id": "error_text",        "label": "t:sections.dim_email_optin.label_error_text",        "default": "t:sections.dim_email_optin.error_text_default" },

    { "type": "header", "content": "t:sections.dim_email_optin.header_compliance" },
    { "type": "text", "id": "consent_text", "label": "t:sections.dim_email_optin.label_consent_text", "info": "t:sections.dim_email_optin.info_consent_text", "default": "t:compliance.email_consent" },
    { "type": "url",  "id": "privacy_url",  "label": "t:sections.dim_email_optin.label_privacy_url" }
  ],
  "presets": [
    { "name": "t:sections.dim_email_optin.preset_name" }
  ]
}
{% endschema %}
