        { "type": "row", "settings": { "label": "t:sections.dim_comparison.row_6_label", "cell_1_text": "t:sections.dim_comparison.row_6_cell_1", "cell_1_status": "ok",   "cell_2_text": "t:sections.dim_comparison.row_6_cell_2", "cell_2_status": "bad",  "cell_3_text": "t:sections.dim_comparison.row_6_cell_3", "cell_3_status": "bad",  "cell_4_text": "t:sections.dim_comparison.row_6_cell_4", "cell_4_status": "bad" } }
