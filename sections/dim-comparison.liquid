        { "type": "text",   "id": "cell_1_text",   "label": "t:sections.dim_comparison.label_cell_1_text" },
        { "type": "select", "id": "cell_1_status", "label": "t:sections.dim_comparison.label_cell_1_status", "options": [
            { "value": "ok",      "label": "t:sections.dim_comparison.status_option_ok" },
            { "value": "warn",    "label": "t:sections.dim_comparison.status_option_warn" },
            { "value": "bad",     "label": "t:sections.dim_comparison.status_option_bad" },
            { "value": "neutral", "label": "t:sections.dim_comparison.status_option_neutral" }
          ], "default": "neutral"
        },
        { "type": "text",   "id": "cell_2_text",   "label": "t:sections.dim_comparison.label_cell_2_text" },
        { "type": "select", "id": "cell_2_status", "label": "t:sections.dim_comparison.label_cell_2_status", "options": [
            { "value": "ok",      "label": "t:sections.dim_comparison.status_option_ok" },
            { "value": "warn",    "label": "t:sections.dim_comparison.status_option_warn" },
            { "value": "bad",     "label": "t:sections.dim_comparison.status_option_bad" },
            { "value": "neutral", "label": "t:sections.dim_comparison.status_option_neutral" }
          ], "default": "neutral"
        },
        { "type": "text",   "id": "cell_3_text",   "label": "t:sections.dim_comparison.label_cell_3_text" },
        { "type": "select", "id": "cell_3_status", "label": "t:sections.dim_comparison.label_cell_3_status", "options": [
            { "value": "ok",      "label": "t:sections.dim_comparison.status_option_ok" },
            { "value": "warn",    "label": "t:sections.dim_comparison.status_option_warn" },
            { "value": "bad",     "label": "t:sections.dim_comparison.status_option_bad" },
            { "value": "neutral", "label": "t:sections.dim_comparison.status_option_neutral" }
          ], "default": "neutral"
        },
        { "type": "text",   "id": "cell_4_text",   "label": "t:sections.dim_comparison.label_cell_4_text" },
        { "type": "select", "id": "cell_4_status", "label": "t:sections.dim_comparison.label_cell_4_status", "options": [
            { "value": "ok",      "label": "t:sections.dim_comparison.status_option_ok" },
            { "value": "warn",    "label": "t:sections.dim_comparison.status_option_warn" },
            { "value": "bad",     "label": "t:sections.dim_comparison.status_option_bad" },
            { "value": "neutral", "label": "t:sections.dim_comparison.status_option_neutral" }
          ], "default": "neutral"
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "t:sections.dim_comparison.preset_name",
      "blocks": [
        { "type": "row", "settings": { "label": "t:sections.dim_comparison.row_1_label", "cell_1_text": "t:sections.dim_comparison.row_1_cell_1", "cell_1_status": "ok",   "cell_2_text": "t:sections.dim_comparison.row_1_cell_2", "cell_2_status": "warn", "cell_3_text": "t:sections.dim_comparison.row_1_cell_3", "cell_3_status": "bad",  "cell_4_text": "t:sections.dim_comparison.row_1_cell_4", "cell_4_status": "bad" } },
        { "type": "row", "settings": { "label": "t:sections.dim_comparison.row_2_label", "cell_1_text": "t:sections.dim_comparison.row_2_cell_1", "cell_1_status": "ok",   "cell_2_text": "t:sections.dim_comparison.row_2_cell_2", "cell_2_status": "warn", "cell_3_text": "t:sections.dim_comparison.row_2_cell_3", "cell_3_status": "bad",  "cell_4_text": "t:sections.dim_comparison.row_2_cell_4", "cell_4_status": "bad" } },
        { "type": "row", "settings": { "label": "t:sections.dim_comparison.row_3_label", "cell_1_text": "t:sections.dim_comparison.row_3_cell_1", "cell_1_status": "ok",   "cell_2_text": "t:sections.dim_comparison.row_3_cell_2", "cell_2_status": "bad",  "cell_3_text": "t:sections.dim_comparison.row_3_cell_3", "cell_3_status": "bad",  "cell_4_text": "t:sections.dim_comparison.row_3_cell_4", "cell_4_status": "bad" } },
        { "type": "row", "settings": { "label": "t:sections.dim_comparison.row_4_label", "cell_1_text": "t:sections.dim_comparison.row_4_cell_1", "cell_1_status": "ok",   "cell_2_text": "t:sections.dim_comparison.row_4_cell_2", "cell_2_status": "warn", "cell_3_text": "t:sections.dim_comparison.row_4_cell_3", "cell_3_status": "bad",  "cell_4_text": "t:sections.dim_comparison.row_4_cell_4", "cell_4_status": "warn" } },
