{%- comment -%}
  section: dim-quiz
  source mapping: index.html block 1.5 (lines 256-315)
  Turn 5 (Batch B). First quiz wizard. <dim-quiz> Web Component, lazy-init via IO.
  1 CTA via cta-button (quiz-result-cta).
{%- endcomment -%}

<dim-quiz class="quiz" persist-key="dim-quiz-v1" {{ section.shopify_attributes }}>
  <div class="container">
    <div class="quiz__head">
      {%- if section.settings.eyebrow != blank -%}
        <div class="eyebrow">{{ section.settings.eyebrow }}</div>
      {%- endif -%}
      <h2 class="h2">{{ section.settings.h2 }}</h2>
      {%- if section.settings.lede != blank -%}
        <p class="lede">{{ section.settings.lede }}</p>
      {%- endif -%}
    </div>

    <div class="quiz__progress" aria-label="{{ 'sections.dim_quiz.progress_aria' | t }}">
      <div class="quiz__progress-bar"
           data-quiz-bar
           role="progressbar"
           aria-valuemin="0" aria-valuemax="100" aria-valuenow="0"></div>
    </div>

    {%- assign question_blocks = section.blocks | where: 'type', 'question' -%}
    {%- for block in question_blocks -%}
      <div class="quiz__step" data-step="{{ forloop.index }}" {% unless forloop.first %}hidden{% endunless %} {{ block.shopify_attributes }}>
        <h3 class="quiz__q">{{ block.settings.heading }}</h3>
        <div class="quiz__opts">
          {%- if block.settings.option_1_label != blank -%}
            <button class="quiz__opt" type="button" data-val="{{ block.settings.option_1_value | escape }}">{{ block.settings.option_1_label }}</button>
          {%- endif -%}
          {%- if block.settings.option_2_label != blank -%}
            <button class="quiz__opt" type="button" data-val="{{ block.settings.option_2_value | escape }}">{{ block.settings.option_2_label }}</button>
          {%- endif -%}
          {%- if block.settings.option_3_label != blank -%}
            <button class="quiz__opt" type="button" data-val="{{ block.settings.option_3_value | escape }}">{{ block.settings.option_3_label }}</button>
          {%- endif -%}
          {%- if block.settings.option_4_label != blank -%}
            <button class="quiz__opt" type="button" data-val="{{ block.settings.option_4_value | escape }}">{{ block.settings.option_4_label }}</button>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}

    {%- assign result_blocks = section.blocks | where: 'type', 'result_card' -%}
    {%- if result_blocks.size > 0 -%}
      {%- for block in result_blocks -%}
        <div class="quiz__step quiz__result quiz__result--{{ block.settings.outcome_value | escape }}"
             data-outcome="{{ block.settings.outcome_value | escape }}"
             hidden {{ block.shopify_attributes }}>
          {%- if block.settings.badge != blank -%}
            <div class="quiz__result-badge">{{ block.settings.badge }}</div>
          {%- endif -%}
          <h3 class="quiz__result-h">{{ block.settings.heading }}</h3>
          <p class="quiz__result-p">{{ block.settings.paragraph }}</p>
          {%- render 'cta-button',
            url: settings.global_cta_url,
            label: block.settings.cta_label,
            icon: section.settings.cta_icon,
            cta_id: 'quiz-result-cta',
            section_id: 'quiz',
            position: 'inline',
            size: 'lg'
          -%}
          {%- if block.settings.micro != blank -%}
            <p class="quiz__result-micro">{{ block.settings.micro }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    {%- endif -%}

    <div class="quiz__step quiz__result quiz__result--default" data-outcome="_default" hidden>
      {%- if section.settings.result_badge != blank -%}
        <div class="quiz__result-badge">{{ section.settings.result_badge }}</div>
      {%- endif -%}
      <h3 class="quiz__result-h">{{ section.settings.result_h }}</h3>
      <p class="quiz__result-p">{{ section.settings.result_p }}</p>
      {%- render 'cta-button',
        url: settings.global_cta_url,
        label: section.settings.cta_label,
        icon: section.settings.cta_icon,
        cta_id: 'quiz-result-cta',
        section_id: 'quiz',
        position: 'inline',
        size: 'lg'
      -%}
      {%- if section.settings.result_micro != blank -%}
        <p class="quiz__result-micro">{{ section.settings.result_micro }}</p>
      {%- endif -%}
    </div>
  </div>
</dim-quiz>

<script src="{{ 'dim-quiz.js' | asset_url }}" type="module" defer></script>

