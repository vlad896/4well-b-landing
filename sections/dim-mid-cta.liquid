{%- comment -%}
  section: dim-mid-cta
  source mapping: index.html blocks 8.5 + 10.5 (lines 616-632, 852-868)
  Turn 13 (Batch D). Reusable mid-page CTA, instanced twice in templates/index.json
  (mid-cta-1, mid-cta-2). Each instance produces its own data-cta-id = section.id.
  Optional lifestyle background photo (image_picker overrides theme-asset fallback).
{%- endcomment -%}

{%- liquid
  assign bg_url = ''
  if section.settings.background_image != blank
    assign bg_url = section.settings.background_image | image_url: width: 2400
  elsif section.settings.background_image_fallback != blank
    assign bg_url = section.settings.background_image_fallback | asset_url
  endif
-%}

<section class="mid-cta section--tight{% if bg_url != blank %} mid-cta--has-bg{% endif %}"
         {%- if bg_url != blank %} style="background-image:url('{{ bg_url }}')"{%- endif %}
         {{ section.shopify_attributes }}>
  <div class="container">
    <div class="mid-cta__card">
      <div class="mid-cta__copy">
        {%- if section.settings.eyebrow != blank -%}
          <div class="eyebrow">{{ section.settings.eyebrow }}</div>
        {%- endif -%}
        <h2 class="mid-cta__h">{{ section.settings.h2 }}</h2>
        {%- if section.settings.sub != blank -%}
          <p class="mid-cta__sub">{{ section.settings.sub }}</p>
        {%- endif -%}
      </div>
      {%- render 'cta-button',
        url: settings.global_cta_url,
        label: section.settings.cta_label,
        icon: section.settings.cta_icon,
        cta_id: section.id,
        section_id: section.id,
        position: 'mid'
      -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "t:sections.dim_mid_cta.section_name",
  "tag": "div",
  "class": "dim-section dim-mid-cta-wrapper",
  "settings": [
    { "type": "paragraph", "content": "t:sections.dim_mid_cta.paragraph_id_info" },
    { "type": "text",     "id": "eyebrow",   "label": "t:sections.dim_mid_cta.label_eyebrow",   "default": "t:sections.dim_mid_cta.eyebrow_default" },
    { "type": "text",     "id": "h2",        "label": "t:sections.dim_mid_cta.label_h2",        "default": "t:sections.dim_mid_cta.h2_default" },
    { "type": "textarea", "id": "sub",       "label": "t:sections.dim_mid_cta.label_sub",       "default": "t:sections.dim_mid_cta.sub_default" },
    { "type": "text",     "id": "cta_icon",  "label": "t:sections.dim_mid_cta.label_cta_icon",  "default": "t:sections.dim_mid_cta.cta_icon_default" },
    { "type": "text",     "id": "cta_label", "label": "t:sections.dim_mid_cta.label_cta_label", "default": "t:sections.dim_mid_cta.cta_label_default" },

    { "type": "header", "content": "t:sections.dim_mid_cta.header_background" },
    { "type": "image_picker", "id": "background_image",          "label": "t:sections.dim_mid_cta.label_background_image",          "info": "t:sections.dim_mid_cta.info_background_image" },
    { "type": "text",         "id": "background_image_fallback", "label": "t:sections.dim_mid_cta.label_background_image_fallback", "info": "t:sections.dim_mid_cta.info_background_image_fallback" }
  ],
  "presets": [
    { "name": "t:sections.dim_mid_cta.preset_name" }
  ]
}
{% endschema %}
